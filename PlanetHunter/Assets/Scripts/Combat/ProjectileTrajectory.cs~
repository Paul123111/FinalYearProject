using UnityEngine;

public class ProjectileTrajectory : MonoBehaviour
{
    
    [SerializeField] float speed = 5f;

    void Start()
    {
        
    }

    void Update()
    {
        transform.position += transform.right * speed * Time.deltaTime;
        //transform.position += new Vector3(1, 0, 0);
        //Debug.Log(transform.forward);
    }
}
