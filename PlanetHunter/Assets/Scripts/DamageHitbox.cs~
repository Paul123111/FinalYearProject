using UnityEngine;

public class DamageHitbox : MonoBehaviour
{
 
    public float damage = -50f;
    public bool destroyOnHit = false;
    [SerializeField] bool _isEnemy = false;

    public bool isEnemy {get {return _isEnemy;}}

    void Start() {
    }

    void OnTriggerEnter2D(Collider2D col) {
        Debug.Log(col.transform.parent.tag);
        if (_isEnemy && col.transform.parent.tag != "Player") {
            return;
        } else if (!_isEnemy && col.transform.parent.tag == "Player") {
            return;
        }

        HealthSystem healthSystem = col.gameObject.transform.parent.gameObject.GetComponentInChildren<HealthSystem>();
        if (healthSystem != null) {
            healthSystem.ChangeHealth(damage);
            if (destroyOnHit) {
                Destroy(gameObject);
            }
        }
    }

    public void SetEnemy(bool isEnemy) {
        _isEnemy = isEnemy;
    }
}

