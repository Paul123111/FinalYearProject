using UnityEngine;
using UnityEngine.InputSystem;

public class PlayerScript : MonoBehaviour
{

    [SerializeField] UnitStats stats;
    UnitMovement move;
    HealthSystem healthSystem;
    UseEquipment equip;
    Camera camera;

    void Awake() {
        move = GetComponent<UnitMovement>();
        equip = GetComponent<UseEquipment>();
        healthSystem = GetComponentInChildren<HealthSystem>();
        camera = Camera.main;
        move.SetStats(stats);
        healthSystem.SetStats(stats);
    }

    // Update is called once per frame
    void Update()
    {
        move.SetTarget(camera.ScreenToWorldPoint(Mouse.current.position.ReadValue()));
    }
    
    void OnMove(InputValue value) {
        Vector2 moveValue = value.Get<Vector2>();
        move.SetDirection(new Vector3(moveValue.x, moveValue.y));
    }
    
    void OnAttack(InputValue value) {
        equip.SetAttacking(value.Get<float>());
    }
}
