using UnityEngine;

public class ProjectilePool : PoolController2D<ProjectileScript>
{
    [SerializeField] ProjectileProperties _props;

    public void SpawnProjectile(Transform t, bool isEnemy) {
        var itemObject = SpawnOne();
        itemObject.Setup(_pool, t, isEnemy, _props);
        itemObject.ActivateAt(t.position);
    }
}
